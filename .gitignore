# ─── Secrets ──────────────────────────────────────────────────────────────────
.env

# ─── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pycache

# ─── Compiled Java bytecode ───────────────────────────────────────────────────
proxy/SimpleProxy.class
*.class

# ─── Run logs and generated outputs (contain IOC data) ───────────────────────
# Ignore all content but keep the directory structure via .gitkeep
output/logs/json/*
!output/logs/json/.gitkeep
output/logs/csv/*
!output/logs/csv/.gitkeep
output/cache/*
!output/cache/.gitkeep
*.log

# ─── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
.env.bak

# ─── OS junk ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── IDEs ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ─── Copilot workspace prompt files (session-specific dev notes) ──────────────
.github/prompts/

# ─── Distribution / packaging ─────────────────────────────────────────────────
dist/
build/
*.egg-info/
