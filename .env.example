# ============================================================
#  ArCHie Analyzer - API Keys
#  1. Run:  copy .env.example .env
#  2. Fill in your keys below
#  Tool works without keys - missing ones show NO KEY, never crashes
#
#  MULTI-KEY SUPPORT
#  Every source supports N API keys from N different accounts.
#  Just follow the numbered convention:
#
#    VT_API_KEY=        <- account 1 (primary)
#    VT_API_KEY_2=      <- account 2
#    VT_API_KEY_3=      <- account 3
#    ...and so on
#
#  The tool rotates keys automatically on any 429 response and the
#  rate limiter scales its per-minute limit proportionally.
#  Numbering must be contiguous - no gaps (1, 2, 3... not 1, 3).
# ============================================================

# VirusTotal - https://www.virustotal.com/gui/join-us
# Free: 4 req/min | 500/day
VT_API_KEY=
VT_API_KEY_2=
# VT_API_KEY_3=   <- uncomment and fill to add a third key

# AbuseIPDB - https://www.abuseipdb.com/register
# Free: 1,000 checks/day
ABUSEIPDB_KEY=
ABUSEIPDB_KEY_2=

# OTX AlienVault - https://otx.alienvault.com/api
# Free: generous rate limits, covers hash/IP/domain/URL
OTX_KEY=
OTX_KEY_2=

# GreyNoise - https://viz.greynoise.io/account/signup
# Free Community: 50 checks/day (Personal Access Token)
GREYNOISE_KEY=
GREYNOISE_KEY_2=

# URLScan.io - https://urlscan.io/user/signup
# Free: generous quota
URLSCAN_KEY=
URLSCAN_KEY_2=

# MalwareBazaar - https://bazaar.abuse.ch/
# Sign in -> Account -> API Key (free, requires account)
MALWAREBAZAAR_KEY=
MALWAREBAZAAR_KEY_2=

# Hybrid Analysis - https://www.hybrid-analysis.com/signup
# Free sandbox reports for hashes (MD5 / SHA1 / SHA256)
HYBRID_ANALYSIS_KEY=
HYBRID_ANALYSIS_KEY_2=

# PhishTank - https://www.phishtank.com/developer_info.php
# Free verified phishing URL database (CISO email triage)
PHISHTANK_KEY=
PHISHTANK_KEY_2=

# NVD (National Vulnerability Database) - https://nvd.nist.gov/developers/request-an-api-key
# Optional - without key: 5 req/30s, with key: 50 req/30s
NVD_API_KEY=
NVD_API_KEY_2=

# IPInfo - leave blank for basic geo (no key needed)
# Optional key: https://ipinfo.io/signup for 50k/month
IPINFO_KEY=
IPINFO_KEY_2=

# ---- Rate Limits (requests per minute) ----
# Leave blank to use the default shown in the comment.
# Values auto-scale with key count: 2 keys = 2x default, 3 keys = 3x, etc.
# Set to 0 to disable throttling for that source entirely.
#
#   Upgrade examples:
#     Standard VirusTotal (1000/min): RATE_LIMIT_VIRUSTOTAL=1000
#     Unlimited:                      RATE_LIMIT_VIRUSTOTAL=0
#
RATE_LIMIT_VIRUSTOTAL=      # default:  4/min  | Free: 4/min | Standard: 1000/min
RATE_LIMIT_ABUSEIPDB=       # default: 60/min  | Free: ~1000 checks/day
RATE_LIMIT_GREYNOISE=       # default:  3/min  | Community: 50 checks/day
RATE_LIMIT_OTX=             # default: 60/min  | Free tier is generous
RATE_LIMIT_URLSCAN=         # default: 10/min  | Free tier quota
RATE_LIMIT_MALWAREBAZAAR=   # default: 30/min
RATE_LIMIT_HYBRID_ANALYSIS= # default:  5/min
RATE_LIMIT_PHISHTANK=       # default: 30/min
RATE_LIMIT_IPINFO=          # default: 60/min  | Free: 50k requests/month
RATE_LIMIT_CRTSH=           # default: 30/min  | Public API, no key required
RATE_LIMIT_NVD=             # default:  5/min  | 50/min with API key

# ---- Cache ----
# How long to keep cached results before re-querying (hours). Default: 24
# Examples: 6 (6 hours), 48 (2 days), 168 (1 week)
CACHE_TTL_HOURS=24

# ---- Proxy (do not change) ----
PROXY_HOST=127.0.0.1
PROXY_PORT=8888